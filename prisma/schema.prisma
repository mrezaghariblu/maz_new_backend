generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AcademicYear {
  id                     Int                      @id @default(autoincrement())
  label                  String                   @db.VarChar(20)
  startDate              DateTime
  endDate                DateTime
  isActive               Boolean                  @default(false)
  isArchived             Boolean                  @default(false)
  createdAt              DateTime                 @default(now())
  auditLogs              AuditLog[]
  centerStatusHistory    CenterStatusHistory[]
  personnelStatusHistory PersonnelStatusHistory[]
  studentEnrollments     StudentEnrollment[]
  studentStatusHistory   StudentStatusHistory[]
  userAssignments        UserCenterAssignment[]
  classRooms             ClassRoom[]
  classTeacherAssignments ClassTeacherAssignment[]
  studentClassAssignments StudentClassAssignment[]
  promotionDecisions      StudentPromotionDecision[]

  @@map("academic_years")
}

/// جدول واحد برای تمام مقادیر مرجع/ثابت سیستم (به‌جای enum‌های پراکنده)
/// هر دسته با groupKey مشخص می‌شه و از طریق همون تگ فیلتر/مرتب‌سازی می‌شه.
/// گروه‌های فعلی: DISTRICT, DISABILITY_TYPE, CENTER_TYPE, EDUCATION_LEVEL,
/// EMPLOYMENT_TYPE, JOB_POSITION, EDUCATION_DEGREE, MARITAL_STATUS,
/// EMPLOYMENT_CATEGORY, PHYSICAL_STATUS, FIELD_OF_STUDY, SUBJECT
model LookupValue {
  id        Int     @id @default(autoincrement())
  groupKey  String  @db.VarChar(40)
  code      String  @db.VarChar(40)
  label     String  @db.VarChar(150)
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  centersByType     Center[] @relation("CenterType")
  centersByDistrict Center[] @relation("CenterDistrict")

  usersByDistrict           User[] @relation("UserDistrict")
  usersByEmploymentType     User[] @relation("UserEmploymentType")
  usersByJobPosition        User[] @relation("UserJobPosition")
  usersByEducationDegree    User[] @relation("UserEducationDegree")
  usersByMaritalStatus      User[] @relation("UserMaritalStatus")
  usersByEmploymentCategory User[] @relation("UserEmploymentCategory")
  usersByPhysicalStatus     User[] @relation("UserPhysicalStatus")
  userDisabilityAssignments    UserDisability[]    @relation("UserDisabilityAssignments")

  studentsByPhysicalStatus Student[] @relation("StudentPhysicalStatus")
  studentDisabilityAssignments StudentDisability[] @relation("StudentDisabilityAssignments")

  enrollmentsByEducationLevel StudentEnrollment[] @relation("EnrollmentEducationLevel")

  // مقاطع → پایه‌ها (Grade.educationLevelId)
  gradesByEducationLevel Grade[] @relation("GradeEducationLevel")
  // دروس تخصیص‌یافته به کلاس (ClassTeacherAssignment.subjectId)
  classAssignmentsBySubject ClassTeacherAssignment[] @relation("ClassAssignmentSubject")

  // student relations
  studentsByEducationLevel    Student[] @relation("StudentEducationLevel")
  studentsByFieldOfStudy      Student[] @relation("StudentFieldOfStudy")
  studentsByDistrict          Student[] @relation("StudentDistrict")
  studentsByBookType          Student[] @relation("StudentBookType")
  studentsBySpeechDisorder    Student[] @relation("StudentSpeechDisorder")
  studentGuardianPhysical     Student[] @relation("StudentGuardianPhysical")
  studentSecondGuardianPhysical Student[] @relation("StudentSecondGuardianPhysical")
  studentAssistiveDevices     StudentAssistiveDevice[] @relation("StudentAssistiveDevices")

  @@unique([groupKey, code])
  @@index([groupKey, sortOrder])
  @@map("lookup_values")
}

model Center {
  id                                 Int                    @id @default(autoincrement())
  name                               String                 @db.VarChar(150)
  code                               String                 @unique @db.VarChar(20)
  centerTypeId                       Int
  province                           String                 @db.VarChar(50)
  city                               String                 @db.VarChar(50)
  districtId                         Int?
  address                            String?                @db.Text
  phone                              String?                @db.VarChar(20)
  bankAccountNumber                  String?                @db.VarChar(40)
  shabaNumber                        String?                @db.VarChar(26)
  establishedYear                    Int?                   @db.SmallInt
  preSchoolCode                      String?                @db.VarChar(20)
  primaryCode                        String?                @db.VarChar(20)
  firstMiddleCode                    String?                @db.VarChar(20)
  firstMiddleVocationalCode          String?                @db.VarChar(20)
  secondMiddleSpecialVocationalCode  String?                @db.VarChar(20)
  secondMiddleCode                   String?                @db.VarChar(20)
  isActive                           Boolean                @default(true)
  createdAt                          DateTime               @default(now())
  updatedAt                          DateTime               @updatedAt
  centerType                         LookupValue            @relation("CenterType", fields: [centerTypeId], references: [id])
  district                           LookupValue?           @relation("CenterDistrict", fields: [districtId], references: [id])
  centerStatuses                     CenterStatusHistory[]
  studentEnrollments                 StudentEnrollment[]
  userAssignments                    UserCenterAssignment[]
  classRooms                         ClassRoom[]
  students                           Student[]             @relation("StudentCenter")

  @@index([centerTypeId], map: "centers_centerTypeId_fkey")
  @@index([districtId], map: "centers_districtId_fkey")
  @@map("centers")
}

model User {
  id                     Int                      @id @default(autoincrement())
  nationalCode           String                   @unique @db.VarChar(10)
  personnelCode          String?                  @unique @db.VarChar(20)
  firstName              String                   @db.VarChar(80)
  lastName               String                   @db.VarChar(80)
  fatherName             String?                  @db.VarChar(80)
  gender                 Gender
  userType               UserType
  phone                  String?                  @db.VarChar(20)
  email                  String?                  @db.VarChar(120)
  birthDate              DateTime?
  birthDay               Int?                     @db.TinyInt
  birthMonth             Int?                     @db.TinyInt
  birthYearShamsi         Int?                    @db.SmallInt

  // اشتغال
  employmentTypeId       Int?
  jobPositionId          Int?
  employmentCategoryId   Int?
  requiredHours          Decimal?                 @db.Decimal(5, 2)
  nonRequiredHours       Decimal?                 @db.Decimal(5, 2)

  // تاریخچه ورود و سابقه (شمسی)
  exceptionalEntryDay    Int?                     @db.TinyInt
  exceptionalEntryMonth  Int?                     @db.TinyInt
  exceptionalEntryYear   Int?                     @db.SmallInt
  serviceRecordYears     Int?                     @db.SmallInt
  serviceRecordMonths    Int?                     @db.TinyInt
  serviceRecordDays      Int?                     @db.TinyInt

  // اطلاعات فردی و تحصیلی
  maritalStatusId        Int?
  educationDegreeId      Int?
  fieldOfStudy           String?                  @db.VarChar(100)
  isargariStatus         String?                  @db.VarChar(150)
  physicalStatusId       Int?

  // تماس و بانک
  address                String?                  @db.Text
  bankAccountNumber      String?                  @db.VarChar(40)
  shadMobileNumber       String?                  @db.VarChar(20)
  shadUsername           String?                  @db.VarChar(60)
  districtId              Int?

  // داوری مسابقات
  willingJudgeCultural   Boolean                  @default(false)
  willingJudgeQuranEtrat Boolean                  @default(false)
  willingJudgeSports     Boolean                  @default(false)
  judgeCertificateField  String?                  @db.VarChar(100)

  canLogin               Boolean                  @default(false)
  passwordHash           String?                  @db.VarChar(255)
  refreshToken           String?                  @db.VarChar(512)
  isActive               Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  district               LookupValue?             @relation("UserDistrict", fields: [districtId], references: [id])
  employmentType         LookupValue?             @relation("UserEmploymentType", fields: [employmentTypeId], references: [id])
  jobPosition            LookupValue?             @relation("UserJobPosition", fields: [jobPositionId], references: [id])
  educationDegree        LookupValue?             @relation("UserEducationDegree", fields: [educationDegreeId], references: [id])
  maritalStatus          LookupValue?             @relation("UserMaritalStatus", fields: [maritalStatusId], references: [id])
  employmentCategory     LookupValue?             @relation("UserEmploymentCategory", fields: [employmentCategoryId], references: [id])
  physicalStatus         LookupValue?             @relation("UserPhysicalStatus", fields: [physicalStatusId], references: [id])
  disabilities           UserDisability[]

  auditLogsPerformed     AuditLog[]               @relation("AuditPerformedBy")
  personnelStatusHistory PersonnelStatusHistory[]
  centerAssignments      UserCenterAssignment[]
  classTeacherAssignments ClassTeacherAssignment[]
  promotionDecisions     StudentPromotionDecision[] @relation("PromotionDecisionBy")

  @@index([userType])
  @@index([nationalCode])
  @@index([personnelCode])
  @@index([jobPositionId], map: "users_jobPositionId_fkey")
  @@index([employmentTypeId], map: "users_employmentTypeId_fkey")
  @@index([districtId], map: "users_districtId_fkey")
  @@map("users")
}

model UserCenterAssignment {
  id             Int          @id @default(autoincrement())
  userId         Int
  centerId       Int
  academicYearId Int
  assignedAt     DateTime     @default(now())
  revokedAt      DateTime?
  note           String?      @db.Text
  isPrimary      Boolean      @default(true)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  center         Center       @relation(fields: [centerId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([userId, academicYearId])
  @@index([centerId, academicYearId])
  @@index([academicYearId], map: "user_center_assignments_academicYearId_fkey")
  @@map("user_center_assignments")
}

model Student {
  id           Int    @id @default(autoincrement())

  // ─── هویتی ─────────────────────────────────────────────────
  nationalCode String  @unique @db.VarChar(10)
  firstName    String  @db.VarChar(80)
  lastName     String  @db.VarChar(80)
  gender       Gender
  birthDay     Int?    @db.TinyInt
  birthMonth   Int?    @db.TinyInt
  birthYearShamsi Int? @db.SmallInt
  address      String? @db.Text
  homePhone    String? @db.VarChar(20)

  // ─── ولی/قیم قانونی (پدر یا قیم) ──────────────────────────
  guardianName         String?  @db.VarChar(100)
  guardianNationalCode String?  @db.VarChar(10)
  guardianPhone        String?  @db.VarChar(20)
  guardianPhysicalStatusId Int?   // وضعیت جسمی ولی (از LookupValue گروه DISABILITY_TYPE یا سالم)
  guardianPhysicalStatus   LookupValue? @relation("StudentGuardianPhysical", fields: [guardianPhysicalStatusId], references: [id])

  // ─── ولی دوم (مادر) ─────────────────────────────────────────
  secondGuardianName         String? @db.VarChar(100)
  secondGuardianNationalCode String? @db.VarChar(10)
  secondGuardianPhone        String? @db.VarChar(20)
  secondGuardianPhysicalStatusId Int?
  secondGuardianPhysicalStatus   LookupValue? @relation("StudentSecondGuardianPhysical", fields: [secondGuardianPhysicalStatusId], references: [id])

  // ─── تحصیلی ────────────────────────────────────────────────
  // educationLevelId و gradeId از LookupValue/Grade — پایه و مقطع
  // centerId نگه می‌داریم تا بدونیم دانش‌آموز الان در کدام مدرسه‌ست (auto-set)
  educationLevelId Int?
  educationLevel   LookupValue? @relation("StudentEducationLevel", fields: [educationLevelId], references: [id])
  gradeId          Int?
  grade            Grade?       @relation(fields: [gradeId], references: [id])
  fieldOfStudyId   Int?         // رشته (فقط متوسطه دوم)
  fieldOfStudy     LookupValue? @relation("StudentFieldOfStudy", fields: [fieldOfStudyId], references: [id])
  centerId         Int?         // مدرسه فعلی (auto-set از enrollment)
  center           Center?      @relation("StudentCenter", fields: [centerId], references: [id])
  districtId       Int?         // ناحیه (auto-set از مرکز)
  district         LookupValue? @relation("StudentDistrict", fields: [districtId], references: [id])
  attendanceType   AttendanceType @default(SCHOOL_PRESENCE)
  entryDay         Int?   @db.TinyInt   // روز ورود به مدرسه استثنایی (شمسی)
  entryMonth       Int?   @db.TinyInt
  entryYear        Int?   @db.SmallInt

  // ─── معلولیت و نیازهای ویژه ────────────────────────────────
  physicalStatusId Int?
  physicalStatus   LookupValue? @relation("StudentPhysicalStatus", fields: [physicalStatusId], references: [id])
  bookTypeId       Int?         // نوع کتاب از LookupValue گروه BOOK_TYPE
  bookType         LookupValue? @relation("StudentBookType", fields: [bookTypeId], references: [id])
  needsOccupationalTherapy Boolean @default(false)
  needsSpeechTherapy       Boolean @default(false)
  needsPhysiotherapy       Boolean @default(false)
  speechDisorderId         Int?    // نوع مشکل گفتاری از LookupValue گروه SPEECH_DISORDER
  speechDisorder           LookupValue? @relation("StudentSpeechDisorder", fields: [speechDisorderId], references: [id])

  // ─── مالی ──────────────────────────────────────────────────
  bankAccountNumber String? @db.VarChar(40)
  shabaNumber       String? @db.VarChar(26)

  // ─── موارد خاص ─────────────────────────────────────────────
  isMartyrFamily     Boolean @default(false) // شاهد و ایثارگر
  isOrphan           Boolean @default(false) // یتیم
  isUnderWelfare     Boolean @default(false) // تحت پوشش بهزیستی
  isUnderRelief      Boolean @default(false) // تحت پوشش کمیته امداد
  hasNonParentGuardian Boolean @default(false) // سرپرست غیر

  // ─── فعالیت‌ها ──────────────────────────────────────────────
  willingCultural Boolean @default(false)
  willingArt      Boolean @default(false)
  willingSports   Boolean @default(false)
  willingQuran    Boolean @default(false)
  achievementsText String? @db.Text // رتبه‌های کسب‌شده (منطقه/استان/کشور) — متن آزاد

  // ─── متفرقه ─────────────────────────────────────────────────
  notes    String? @db.Text
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Relations ─────────────────────────────────────────────
  disabilities         StudentDisability[]
  assistiveDevices     StudentAssistiveDevice[]
  enrollments          StudentEnrollment[]
  classAssignments     StudentClassAssignment[]
  promotionDecisions   StudentPromotionDecision[]
  studentStatusHistory StudentStatusHistory[]

  @@index([nationalCode])
  @@index([educationLevelId], map: "students_educationLevelId_fkey")
  @@index([gradeId], map: "students_gradeId_fkey")
  @@index([centerId], map: "students_centerId_fkey")
  @@index([districtId], map: "students_districtId_fkey")
  @@index([physicalStatusId], map: "students_physicalStatusId_fkey")
  @@index([guardianPhysicalStatusId], map: "students_guardianPhysicalStatusId_fkey")
  @@index([secondGuardianPhysicalStatusId], map: "students_secondGuardianPhysicalStatusId_fkey")
  @@index([bookTypeId], map: "students_bookTypeId_fkey")
  @@index([speechDisorderId], map: "students_speechDisorderId_fkey")
  @@index([fieldOfStudyId], map: "students_fieldOfStudyId_fkey")
  @@map("students")
}

/// وسایل کمکی دانش‌آموز (چندتایی از LookupValue گروه ASSISTIVE_DEVICE)
model StudentAssistiveDevice {
  id               Int         @id @default(autoincrement())
  studentId        Int
  assistiveDeviceId Int
  student          Student     @relation(fields: [studentId], references: [id])
  assistiveDevice  LookupValue @relation("StudentAssistiveDevices", fields: [assistiveDeviceId], references: [id])
  createdAt        DateTime    @default(now())

  @@unique([studentId, assistiveDeviceId])
  @@index([assistiveDeviceId], map: "student_assistive_devices_deviceId_fkey")
  @@map("student_assistive_devices")
}

/// تخصیص دانش‌آموز به کلاس (با پایه‌ی خودش در صورت کلاس چندپایه)
model StudentClassAssignment {
  id           Int       @id @default(autoincrement())
  studentId    Int
  classRoomId  Int
  gradeId      Int       // پایه‌ی خودِ دانش‌آموز در این کلاس
  academicYearId Int
  enrolledAt   DateTime  @default(now())
  revokedAt    DateTime?
  student      Student   @relation(fields: [studentId], references: [id])
  classRoom    ClassRoom @relation(fields: [classRoomId], references: [id])
  grade        Grade     @relation(fields: [gradeId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, academicYearId])
  @@index([classRoomId, academicYearId])
  @@index([gradeId], map: "student_class_assignments_gradeId_fkey")
  @@index([academicYearId], map: "student_class_assignments_academicYearId_fkey")
  @@map("student_class_assignments")
}

/// تصمیم ارتقا/تکرار پایه (خرداد یا شهریور)
model StudentPromotionDecision {
  id             Int              @id @default(autoincrement())
  studentId      Int
  academicYearId Int
  decision       PromotionDecision
  nextGradeId    Int?             // پایه‌ی بعدی (اگه ارتقا)
  decisionById   Int              // تصمیم‌گیرنده (User)
  decidedAt      DateTime         @default(now())
  note           String?          @db.Text
  student        Student          @relation(fields: [studentId], references: [id])
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
  decisionBy     User             @relation("PromotionDecisionBy", fields: [decisionById], references: [id])
  nextGrade      Grade?           @relation("PromotionNextGrade", fields: [nextGradeId], references: [id])

  @@unique([studentId, academicYearId])
  @@index([academicYearId], map: "student_promotion_decisions_academicYearId_fkey")
  @@index([decisionById], map: "student_promotion_decisions_decisionById_fkey")
  @@index([nextGradeId], map: "student_promotion_decisions_nextGradeId_fkey")
  @@map("student_promotion_decisions")
}

model StudentEnrollment {
  id               Int          @id @default(autoincrement())
  studentId        Int
  centerId         Int
  academicYearId   Int
  educationLevelId Int?
  grade            String       @db.VarChar(20)
  field            String?      @db.VarChar(60)
  enrolledAt       DateTime     @default(now())
  academicYear     AcademicYear @relation(fields: [academicYearId], references: [id])
  center           Center       @relation(fields: [centerId], references: [id])
  student          Student      @relation(fields: [studentId], references: [id])
  educationLevel   LookupValue? @relation("EnrollmentEducationLevel", fields: [educationLevelId], references: [id])

  @@unique([studentId, academicYearId])
  @@index([academicYearId], map: "student_enrollments_academicYearId_fkey")
  @@index([centerId], map: "student_enrollments_centerId_fkey")
  @@index([educationLevelId], map: "student_enrollments_educationLevelId_fkey")
  @@map("student_enrollments")
}

/// معلولیت‌های Assign‌شده به پرسنل — یک نفر می‌تونه چند معلولیت داشته باشه.
/// تگ «چندمعلولیتی» نیازی به ستون جدا نداره: همیشه می‌شه با
/// COUNT(*) > 1 GROUP BY userId محاسبه‌ش کرد (در سرویس/کوئری لیست).
model UserDisability {
  id               Int                 @id @default(autoincrement())
  userId           Int
  disabilityTypeId Int
  severity         DisabilitySeverity?
  autismLevel      Int?                @db.TinyInt // فقط برای اوتیسم: ۱، ۲ یا ۳
  createdAt        DateTime            @default(now())
  user             User                @relation(fields: [userId], references: [id])
  disabilityType   LookupValue         @relation("UserDisabilityAssignments", fields: [disabilityTypeId], references: [id])

  @@unique([userId, disabilityTypeId])
  @@index([disabilityTypeId], map: "user_disabilities_disabilityTypeId_fkey")
  @@map("user_disabilities")
}

/// معلولیت‌های Assign‌شده به دانش‌آموز — همون منطق UserDisability
model StudentDisability {
  id               Int                 @id @default(autoincrement())
  studentId        Int
  disabilityTypeId Int
  severity         DisabilitySeverity?
  autismLevel      Int?                @db.TinyInt // فقط برای اوتیسم: ۱، ۲ یا ۳
  createdAt        DateTime            @default(now())
  student          Student             @relation(fields: [studentId], references: [id])
  disabilityType   LookupValue         @relation("StudentDisabilityAssignments", fields: [disabilityTypeId], references: [id])

  @@unique([studentId, disabilityTypeId])
  @@index([disabilityTypeId], map: "student_disabilities_disabilityTypeId_fkey")
  @@map("student_disabilities")
}

model PersonnelStatusType {
  id          Int                      @id @default(autoincrement())
  code        String                   @unique @db.VarChar(40)
  label       String                   @db.VarChar(80)
  description String?                  @db.Text
  isActive    Boolean                  @default(true)
  sortOrder   Int                      @default(0)
  history     PersonnelStatusHistory[]

  @@map("personnel_status_types")
}

model StudentStatusType {
  id        Int                    @id @default(autoincrement())
  code      String                 @unique @db.VarChar(40)
  label     String                 @db.VarChar(80)
  isActive  Boolean                @default(true)
  sortOrder Int                    @default(0)
  history   StudentStatusHistory[]

  @@map("student_status_types")
}

model CenterStatusType {
  id        Int                   @id @default(autoincrement())
  code      String                @unique @db.VarChar(40)
  label     String                @db.VarChar(80)
  isActive  Boolean               @default(true)
  sortOrder Int                   @default(0)
  history   CenterStatusHistory[]

  @@map("center_status_types")
}

model PersonnelStatusHistory {
  id             Int                 @id @default(autoincrement())
  userId         Int
  statusTypeId   Int
  academicYearId Int
  effectiveDate  DateTime
  endDate        DateTime?
  note           String?             @db.Text
  createdAt      DateTime            @default(now())
  academicYear   AcademicYear        @relation(fields: [academicYearId], references: [id])
  statusType     PersonnelStatusType @relation(fields: [statusTypeId], references: [id])
  user           User                @relation(fields: [userId], references: [id])

  @@index([userId, academicYearId])
  @@index([academicYearId], map: "personnel_status_history_academicYearId_fkey")
  @@index([statusTypeId], map: "personnel_status_history_statusTypeId_fkey")
  @@map("personnel_status_history")
}

model StudentStatusHistory {
  id             Int               @id @default(autoincrement())
  studentId      Int
  statusTypeId   Int
  academicYearId Int
  effectiveDate  DateTime
  endDate        DateTime?
  note           String?           @db.Text
  createdAt      DateTime          @default(now())
  academicYear   AcademicYear      @relation(fields: [academicYearId], references: [id])
  statusType     StudentStatusType @relation(fields: [statusTypeId], references: [id])
  student        Student           @relation(fields: [studentId], references: [id])

  @@index([studentId, academicYearId])
  @@index([academicYearId], map: "student_status_history_academicYearId_fkey")
  @@index([statusTypeId], map: "student_status_history_statusTypeId_fkey")
  @@map("student_status_history")
}

model CenterStatusHistory {
  id             Int              @id @default(autoincrement())
  centerId       Int
  statusTypeId   Int
  academicYearId Int
  effectiveDate  DateTime
  endDate        DateTime?
  note           String?          @db.Text
  createdAt      DateTime         @default(now())
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
  center         Center           @relation(fields: [centerId], references: [id])
  statusType     CenterStatusType @relation(fields: [statusTypeId], references: [id])

  @@index([centerId, academicYearId])
  @@index([academicYearId], map: "center_status_history_academicYearId_fkey")
  @@index([statusTypeId], map: "center_status_history_statusTypeId_fkey")
  @@map("center_status_history")
}

model AuditLog {
  id             Int           @id @default(autoincrement())
  academicYearId Int?
  performedById  Int
  entity         String        @db.VarChar(60)
  entityId       Int
  action         String        @db.VarChar(20)
  beforeData     Json?
  afterData      Json?
  ipAddress      String?       @db.VarChar(45)
  createdAt      DateTime      @default(now())
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  performedBy    User          @relation("AuditPerformedBy", fields: [performedById], references: [id])

  @@index([entity, entityId])
  @@index([performedById])
  @@index([createdAt])
  @@index([academicYearId], map: "audit_logs_academicYearId_fkey")
  @@map("audit_logs")
}

/// پایه‌ی تحصیلی — هر پایه به یک مقطع (LookupValue گروه EDUCATION_LEVEL) وصل است.
/// track مشخص می‌کند این پایه مخصوص چه گروهی از دانش‌آموزان است (یا عمومی).
/// branch فقط برای متوسطه اول/دوم معنا دارد: عادی در مقابل پیش‌حرفه‌ای/کاردانش خاص.
model Grade {
  id               Int           @id @default(autoincrement())
  educationLevelId Int
  code             String        @db.VarChar(40)
  label            String        @db.VarChar(100)
  track            GradeTrack    @default(NORMAL)
  branch           GradeBranch   @default(NORMAL)
  sortOrder        Int           @default(0)
  isActive         Boolean       @default(true)
  educationLevel   LookupValue   @relation("GradeEducationLevel", fields: [educationLevelId], references: [id])
  classGrades      ClassGrade[]
  students                  Student[]
  studentClassAssignments   StudentClassAssignment[]
  promotionDecisionsAsNext  StudentPromotionDecision[] @relation("PromotionNextGrade")

  @@unique([educationLevelId, code])
  @@index([educationLevelId], map: "grades_educationLevelId_fkey")
  @@map("grades")
}

/// کلاس درس — متعلق به یک مرکز در یک سال تحصیلی مشخص.
/// «نوع کلاس» (تک/چندپایه، تک/چندمعلولیتی) ذخیره نمی‌شود؛ همیشه در لحظه
/// از روی ClassGrade و معلولیت‌های دانش‌آموزانِ فعلیِ کلاس محاسبه می‌شود.
model ClassRoom {
  id             Int                      @id @default(autoincrement())
  centerId       Int
  academicYearId Int
  name           String                   @db.VarChar(100)
  isActive       Boolean                  @default(true)
  createdAt      DateTime                 @default(now())
  center         Center                   @relation(fields: [centerId], references: [id])
  academicYear   AcademicYear             @relation(fields: [academicYearId], references: [id])
  classGrades    ClassGrade[]
  teacherAssignments ClassTeacherAssignment[]
  studentAssignments StudentClassAssignment[]

  @@index([centerId, academicYearId])
  @@index([academicYearId], map: "class_rooms_academicYearId_fkey")
  @@map("class_rooms")
}

/// پایه‌های یک کلاس (چندبه‌چند) — کلاس می‌تواند چندپایه باشد
model ClassGrade {
  id          Int       @id @default(autoincrement())
  classRoomId Int
  gradeId     Int
  classRoom   ClassRoom @relation(fields: [classRoomId], references: [id])
  grade       Grade     @relation(fields: [gradeId], references: [id])

  @@unique([classRoomId, gradeId])
  @@index([gradeId], map: "class_grades_gradeId_fkey")
  @@map("class_grades")
}

/// تخصیص آموزگار/دبیر به کلاس — subjectId برای دبیرهای متوسطه پر می‌شود
/// (هر دبیر یک درس مشخص)؛ برای آموزگار ابتدایی که همه‌ی دروس را تدریس
/// می‌کند خالی می‌ماند.
model ClassTeacherAssignment {
  id             Int          @id @default(autoincrement())
  classRoomId    Int
  userId         Int
  academicYearId Int
  subjectId      Int?
  assignedAt     DateTime     @default(now())
  revokedAt      DateTime?
  classRoom      ClassRoom    @relation(fields: [classRoomId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  subject        LookupValue? @relation("ClassAssignmentSubject", fields: [subjectId], references: [id])

  @@index([classRoomId, academicYearId])
  @@index([userId], map: "class_teacher_assignments_userId_fkey")
  @@index([academicYearId], map: "class_teacher_assignments_academicYearId_fkey")
  @@index([subjectId], map: "class_teacher_assignments_subjectId_fkey")
  @@map("class_teacher_assignments")
}

enum UserType {
  SUPERUSER
  CENTER_MANAGER
  TEACHER
  STAFF
  STUDENT
}

enum Gender {
  MALE
  FEMALE
}

enum DisabilitySeverity {
  MILD     // خفیف
  MODERATE // متوسط
  SEVERE   // شدید
}

enum GradeTrack {
  NORMAL                // عادی — برای همه
  INTELLECTUAL_AUTISM   // مخصوص کم‌توان ذهنی و اتیسم
  SENSORY_MOTOR         // مخصوص گروه حسی-حرکتی
}

enum GradeBranch {
  NORMAL     // عادی
  VOCATIONAL // پیش‌حرفه‌ای (متوسطه اول) / کاردانش خاص (متوسطه دوم)
}

enum AttendanceType {
  SCHOOL_PRESENCE // حضور در مدرسه
  SPECIAL_COMMISSION_18 // کمیسیون خاص بند ۱۸
}

enum PromotionDecision {
  PROMOTED    // ارتقا به پایه‌ی بعدی
  REPEATED    // تکرار پایه
}
